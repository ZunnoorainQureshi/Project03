---
import Layout from '../layouts/Layout.astro';
import MeshGradient from '../components/MeshGradient.astro';

// Note: Nav and Footer are excluded here because they are handled globally by your main layout shell.
---

<Layout title="App Dashboard | PDFtoQuiz">
  <div class="relative min-h-screen bg-[#0d0d0d] text-white flex flex-col font-sans overflow-x-hidden">
    <MeshGradient />

    <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12 relative z-10 flex flex-col items-center justify-start gap-8">
      
      <div class="text-center max-w-2xl mx-auto mt-4">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight bg-gradient-to-r from-white via-gray-300 to-gray-500 bg-clip-text text-transparent">
          Generate Your Interactive Quiz
        </h1>
        <p class="text-gray-400 mt-2 text-sm md:text-base">
          Upload your .pdf study material or lecture slides to instantly create dynamic mock questions.
        </p>
      </div>

      <div class="w-full bg-[#141414]/90 border border-gray-800/80 rounded-2xl p-6 shadow-xl grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Question Types</label>
          <div class="flex flex-col gap-2">
            <label class="flex items-center gap-2 text-sm cursor-pointer text-gray-300"><input type="checkbox" checked class="accent-red-500 rounded" id="typeMcq"/> Multiple Choice (MCQs)</label>
            <label class="flex items-center gap-2 text-sm cursor-pointer text-gray-300"><input type="checkbox" checked class="accent-red-500 rounded" id="typeTf"/> True / False</label>
            <label class="flex items-center gap-2 text-sm cursor-pointer text-gray-300"><input type="checkbox" checked class="accent-red-500 rounded" id="typeCloze"/> Fill-in-the-Blanks</label>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Difficulty Level</label>
          <select id="difficulty" class="w-full bg-[#1a1a1a] border border-gray-800 rounded-lg p-2.5 text-sm text-gray-300 focus:border-red-500 focus:outline-none">
            <option value="easy">Easy (Concept Check)</option>
            <option value="medium" selected>Medium (Standard Exam)</option>
            <option value="hard">Hard (Deep Analytical)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Timed Mode</label>
          <select id="timer" class="w-full bg-[#1a1a1a] border border-gray-800 rounded-lg p-2.5 text-sm text-gray-300 focus:border-red-500 focus:outline-none">
            <option value="none">No Timer</option>
            <option value="5">5 Minutes</option>
            <option value="15">15 Minutes</option>
            <option value="30">30 Minutes</option>
          </select>
        </div>
      </div>

      <div id="dropzone" class="w-full block border-2 border-dashed border-gray-800 hover:border-red-500/80 rounded-2xl p-16 text-center bg-[#141414]/60 backdrop-blur-md cursor-pointer transition-all group duration-300 shadow-xl">
        <input type="file" id="fileInput" accept=".pdf" class="hidden" />
        <div class="flex flex-col items-center justify-center gap-4 w-full">
          <div class="p-4 bg-red-950/20 rounded-full text-red-500 group-hover:scale-110 transition-transform duration-300 border border-red-900/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
          </div>
          <div class="max-w-md">
            <h3 class="text-xl font-bold tracking-tight mb-2 group-hover:text-red-400 transition-colors">Drag & Drop your Lecture Slides or PDFs</h3>
            <p class="text-gray-400 text-sm leading-relaxed">or click anywhere inside this box to browse local storage</p>
          </div>
          <span class="text-xs bg-[#1a1a1a] px-4 py-2 rounded-full text-gray-500 border border-gray-800/60 mt-2 font-medium">Supports complete .pdf document uploads</span>
        </div>
      </div>

      <div id="processingState" class="hidden w-full max-w-md bg-[#141414] border border-gray-800 rounded-2xl p-8 text-center flex flex-col items-center gap-4 shadow-xl animate-fade-in">
        <div class="relative flex items-center justify-center">
          <div class="animate-spin rounded-full h-12 w-12 border-2 border-gray-800 border-t-red-500"></div>
        </div>
        <div>
          <p class="text-white font-semibold text-base">Processing Document</p>
          <p class="text-gray-400 text-xs mt-1" id="loadingStage">Reading file segments and generating question profiles...</p>
        </div>
      </div>

      <div id="quizContainer" class="hidden w-full bg-[#141414]/90 backdrop-blur-md border border-gray-800 rounded-2xl p-8 shadow-2xl">
        <div class="flex justify-between items-center border-b border-gray-800 pb-4 mb-6">
          <h2 class="text-xl font-bold text-white flex items-center gap-2">
            <span class="inline-block w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
            Active Evaluation Session
          </h2>
          <div id="quizTimerDisplay" class="text-sm font-mono text-red-400 font-semibold bg-red-950/30 px-3 py-1 rounded-md border border-red-950"></div>
        </div>
        <div id="quizQuestions" class="space-y-8"></div>
        <div class="mt-8 pt-6 border-t border-gray-800 flex justify-end">
          <button id="submitQuizBtn" class="bg-red-600 hover:bg-red-500 text-white font-bold px-6 py-3 rounded-xl transition-all duration-200 shadow-lg shadow-red-950/50 hover:scale-[1.02]">
            Complete and Grade Exam
          </button>
        </div>
      </div>

    </main>
  </div>
</Layout>

<script>
  // Dynamic client parsing pipeline targeting src/lib tools
  import { parsePDF } from '../lib/pdf';
  import { generateQuiz } from '../lib/generator';
  import { calculateScore } from '../lib/score';

  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const processingState = document.getElementById('processingState');
  const quizContainer = document.getElementById('quizContainer');
  const quizQuestions = document.getElementById('quizQuestions');
  const loadingStage = document.getElementById('loadingStage');
  const submitQuizBtn = document.getElementById('submitQuizBtn');

  let localGeneratedQuestions: any[] = [];

  dropzone?.addEventListener('click', () => fileInput?.click());

  dropzone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-red-500', 'bg-red-950/10');
  });

  dropzone?.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-red-500', 'bg-red-950/10');
  });

  dropzone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-red-500', 'bg-red-950/10');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) processIncomingFile(files[0]);
  });

  fileInput?.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.files && target.files.length > 0) processIncomingFile(target.files[0]);
  });

  async function processIncomingFile(file: File) {
    if (file.type !== 'application/pdf') {
      alert('Invalid Format: Please drop an authentic .pdf file.');
      return;
    }
    
    // Smooth layout transitions
    if (dropzone) dropzone.style.display = 'none';
    processingState?.classList.remove('hidden');

    try {
      if (loadingStage) loadingStage.innerText = "Extracting underlying structural text from PDF nodes...";
      
      // Step 1: Call your custom parsing engine
      const arrayBuffer = await file.arrayBuffer();
      const extractedText = await parsePDF(arrayBuffer);

      if (loadingStage) loadingStage.innerText = "Analyzing text semantics and structuring question profiles...";
      
      // Grab customization options selected by user
      const difficulty = (document.getElementById('difficulty') as HTMLSelectElement).value;
      const options = {
        difficulty,
        mcq: (document.getElementById('typeMcq') as HTMLInputElement).checked,
        tf: (document.getElementById('typeTf') as HTMLInputElement).checked,
        cloze: (document.getElementById('typeCloze') as HTMLInputElement).checked
      };

      // Step 2: Push into Claude's generator engine logic
      const quiz = await generateQuiz(extractedText, options);
      localGeneratedQuestions = quiz.questions;

      // Step 3: Render questions beautifully
      renderQuizInterface(localGeneratedQuestions);

    } catch (err) {
      console.error("Pipeline failure:", err);
      alert("Error parsing file. Ensure it is text-readable and not scanned/corrupted images.");
      if (dropzone) dropzone.style.display = 'block';
      processingState?.classList.add('hidden');
    }
  }

  function renderQuizInterface(questions: any[]) {
    processingState?.classList.add('hidden');
    quizContainer?.classList.remove('hidden');
    if (!quizQuestions) return;

    quizQuestions.innerHTML = '';

    questions.forEach((q, idx) => {
      const qDiv = document.createElement('div');
      qDiv.className = "p-5 bg-[#1a1a1a]/40 border border-gray-800/60 rounded-xl space-y-3";
      
      let htmlContent = `<p class="font-medium text-gray-200"><span class="text-red-500 font-bold mr-1">Q${idx+1}.</span> ${q.questionText}</p>`;
      
      if (q.type === 'mcq') {
        htmlContent += `<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">`;
        q.options.forEach((opt: string, oIdx: number) => {
          htmlContent += `
            <label class="flex items-center gap-3 p-3 bg-[#111] border border-gray-800 rounded-lg cursor-pointer hover:border-gray-700 transition-colors text-sm text-gray-300">
              <input type="radio" name="q_${idx}" value="${opt}" class="accent-red-500">
              ${opt}
            </label>
          `;
        });
        htmlContent += `</div>`;
      } else if (q.type === 'tf') {
        htmlContent += `
          <div class="flex gap-4 pt-2">
            <label class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border border-gray-800 rounded-lg cursor-pointer text-sm text-gray-300"><input type="radio" name="q_${idx}" value="True" class="accent-red-500"> True</label>
            <label class="flex items-center gap-2 px-4 py-2.5 bg-[#111] border border-gray-800 rounded-lg cursor-pointer text-sm text-gray-300"><input type="radio" name="q_${idx}" value="False" class="accent-red-500"> False</label>
          </div>
        `;
      } else if (q.type === 'cloze') {
        htmlContent += `
          <div class="pt-2">
            <input type="text" name="q_${idx}" placeholder="Type your answer here..." class="w-full max-w-md bg-[#111] border border-gray-800 focus:border-red-500 rounded-lg p-2.5 text-sm text-gray-300 focus:outline-none">
          </div>
        `;
      }

      qDiv.innerHTML = htmlContent;
      quizQuestions.appendChild(qDiv);
    });
  }

  submitQuizBtn?.addEventListener('click', () => {
    // Collect user input selections and evaluate grade using score.ts
    const userAnswers = localGeneratedQuestions.map((q, idx) => {
      if (q.type === 'cloze') {
        const input = document.querySelector(`input[name="q_${idx}"]`) as HTMLInputElement;
        return input ? input.value.trim() : '';
      } else {
        const selected = document.querySelector(`input[name="q_${idx}"]:checked`) as HTMLInputElement;
        return selected ? selected.value : '';
      }
    });

    const assessmentResults = calculateScore(localGeneratedQuestions, userAnswers);
    alert(`Evaluation Complete!\nYour Final Score: ${assessmentResults.score}% (${assessmentResults.correctAnswers} / ${localGeneratedQuestions.length})`);
  });
</script>